{
  "name": "txeventq-transformSinkExample-source",
  "config": {
    "connector.class": "oracle.jdbc.txeventq.kafka.connect.source.TxEventQSourceConnector",
    "tasks.max": "3",
    "kafka.topic": "sourceFromTransformSinkedTEQ",
    "wallet.path": "/etc/kafka-connect/custom-plugins/wallets/freedb",
    "tnsnames.path": "/etc/kafka-connect/custom-plugins/wallets",
    "db_tns_alias": "FREEPDB1",
    "txeventq.queue.name": "HEADER_TRANSFORM_TEQ",
    "txeventq.subscriber": "HeaderTransform0_SUBSCRIBER_LOCAL",
    "key.converter": "org.apache.kafka.connect.converters.ByteArrayConverter",
    "value.converter": "org.apache.kafka.connect.converters.ByteArrayConverter",
    "header.converter": "org.apache.kafka.connect.converters.ByteArrayConverter",
    "bootstrap.servers": "kafka:9092"
  }
}


